{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "github>doist/renovate-config:integrations-base",
        "github>doist/renovate-config:integrations-automerge"
    ],
    "packageRules": [
        {
            "matchPackageNames": ["oxlint", "oxfmt"],
            "groupName": "ox toolchain",
            "description": "Group oxlint and oxfmt updates into a single PR"
        }
    ]
}
